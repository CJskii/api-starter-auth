# ----------------------------
# Core server config
# ----------------------------
PORT=3000
NODE_ENV=development

# ----------------------------
# Auth / security
# ----------------------------
JWT_SECRET=change-me-to-a-long-random-secret
PASSWORD_SALT=10

# ----------------------------
# Logging
# ----------------------------
# LOG_PROFILE controls how noisy logs are.
#
# Allowed values:
#   prod     - production style (minimal noise, safe defaults)
#   info     - normal runtime (1 line per request + important events)
#   verbose  - very chatty debugging (request start, validation logs, extra detail)
#   test     - quiet mode for Jest (warn+ only; ideally almost silent)
#
# Default if not set: info
LOG_PROFILE=info
DOTENV_CONFIG_QUIET=true